{
  "name": "typeweather",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "tsc",
    "build:apk": "eas build --profile preview --platform android --local --output ./builds/typeweather.apk",
    "build:dev": "eas build --profile development --platform android --local --output ./builds/typeweatherDev.apk"
  },
  "dependencies": {
    "@expo/config-plugins": "~9.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "axios": "1.6.7",
    "expo": "^52.0.41",
    "expo-av": "~15.0.2",
    "expo-blur": "~14.0.3",
    "expo-dev-client": "~5.0.15",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-location": "~18.0.10",
    "expo-network": "~7.0.5",
    "expo-notifications": "~0.29.14",
    "expo-sharing": "~13.0.1",
    "expo-status-bar": "~2.0.1",
    "expo-updates": "~0.27.4",
    "lodash.debounce": "^4.0.8",
    "phosphor-react-native": "^2.3.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-maps": "1.18.0",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-view-shot": "^4.0.3",
    "styled-components": "^6.1.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/lodash.debounce": "^4.0.9",
    "@types/react": "~18.3.12",
    "@types/styled-components-react-native": "^5.2.5",
    "eas-cli": "^16.3.3",
    "typescript": "~5.3.3"
  },
  "doctor": {
    "reactNativeDirectoryCheck": {
      "exclude": [
        "lodash.debounce",
        "phosphor-react-native",
        "styled-components",
        "@fortawesome/free-solid-svg-icons"
      ],
      "listUnknownPackages": false
    }
  },
  "private": true
}
